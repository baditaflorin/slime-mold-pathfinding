{
  "name": "slime-mold-pathfinding",
  "version": "0.1.0",
  "private": false,
  "description": "WebGPU Physarum simulator that turns city food sources into emergent transit-route candidates on a map.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/slime-mold-pathfinding.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/clean-pages-assets.mjs && tsc --noEmit && vite build && node scripts/postbuild-pages.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "smoke": "bash scripts/smoke.sh",
    "pages-preview": "node scripts/pages-preview.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hpcc-js/wasm": "^2.33.5",
    "@hpcc-js/wasm-graphviz": "^1.21.5",
    "@tanstack/react-query": "^5.100.9",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
